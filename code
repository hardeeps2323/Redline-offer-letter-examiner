    severity: "high",
    weight: 20,
    keywords: [
      "bank account number", "otp", "cvv", "aadhaar", "pan card number",
      "upi pin", "net banking password", "debit card number", "credit card number",
    ],
  },
  {
    id: "certificate_purchase",
    label: "Asked to buy materials/certificate/kit",
    severity: "high",
    weight: 18,
